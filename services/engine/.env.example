# Server
PORT=4000

# Shared secret for internal-only endpoints (e.g. POST /internal/refresh-metrics)
INTERNAL_ADMIN_SECRET=

# Supabase (service-role key — never expose this to the portal/browser)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Default sender ID used when a message isn't tied to a specific registered sender
DEFAULT_SENDER_ID=Platform

# --- Provider metrics job ---
METRICS_REFRESH_INTERVAL_MS=300000
METRICS_ROLLING_WINDOW_SIZE=200
METRICS_MIN_TERMINAL_MESSAGES=20

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PRICING_COUNTRY=NG
# Exact public URL Twilio calls for delivery status webhooks (used for signature verification)
TWILIO_WEBHOOK_BASE_URL=https://your-engine.example.com

# --- Infobip ---
INFOBIP_BASE_URL=https://xxxxx.api.infobip.com
INFOBIP_API_KEY=

# --- Africa's Talking ---
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_BASE_URL=https://api.africastalking.com

# --- Termii ---
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com

# --- Webhook secret path segments (see src/middleware/webhookVerification.ts) ---
# Generate a long random string for each, e.g. `openssl rand -hex 24`, and use it as part of
# the webhook URL you configure in each provider's dashboard:
#   https://your-engine.example.com/webhooks/infobip/<WEBHOOK_SECRET_INFOBIP>
WEBHOOK_SECRET_INFOBIP=
WEBHOOK_SECRET_AFRICASTALKING=
WEBHOOK_SECRET_TERMII=
